# PostgreSQL Database Configuration
POSTGRES_HOST=postgres_db_17
POSTGRES_PORT=5432
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# Odoo Database Name
POSTGRES_DB=your_database_name

# Odoo Admin Master Password (required by docker-compose)
ADMIN_PASSWD=your_admin_master_password

# Odoo Execution Parameters
# Active configuration for updating some_xbn_module module:
EXEC_ODOO=--db_host=${POSTGRES_HOST} --db_port=${POSTGRES_PORT} --db_user=${POSTGRES_USER} --db_password=${POSTGRES_PASSWORD} -d ${POSTGRES_DB} -u some_xbn_module -c /var/lib/odoo/odoo.runtime.conf

# ============================================
# Additional EXEC_ODOO Configuration Examples
# ============================================

# Update some_xbn_module module:
# EXEC_ODOO=--db_host=${POSTGRES_HOST} --db_port=${POSTGRES_PORT} --db_user=${POSTGRES_USER} --db_password=${POSTGRES_PASSWORD} -d ${POSTGRES_DB} -u some_xbn_module -c /var/lib/odoo/odoo.runtime.conf

# Update translations (i18n):
# EXEC_ODOO=--db_host=${POSTGRES_HOST} --db_port=${POSTGRES_PORT} --db_user=${POSTGRES_USER} --db_password=${POSTGRES_PASSWORD} -d ${POSTGRES_DB} --i18n-overwrite -u all --stop-after-init -c /var/lib/odoo/odoo.runtime.conf

# Database selection mode:
# EXEC_ODOO=--db_host=${POSTGRES_HOST} --db_port=${POSTGRES_PORT} --db_user=${POSTGRES_USER} --db_password=${POSTGRES_PASSWORD} -c /var/lib/odoo/odoo.runtime.conf

# Run with one database:
# EXEC_ODOO=--db_host=${POSTGRES_HOST} --db_port=${POSTGRES_PORT} --db_user=${POSTGRES_USER} --db_password=${POSTGRES_PASSWORD} -d ${POSTGRES_DB} -c /var/lib/odoo/odoo.runtime.conf

# Update all modules in one database and stop:
# EXEC_ODOO=--db_host=${POSTGRES_HOST} --db_port=${POSTGRES_PORT} --db_user=${POSTGRES_USER} --db_password=${POSTGRES_PASSWORD} -d ${POSTGRES_DB} -u all --stop-after-init --log-level=debug -c /var/lib/odoo/odoo.runtime.conf
